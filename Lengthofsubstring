class Solution:
    def lengthOfLongestSubstring(self, s: str) -> int:
        if len(s)==0 :
            return 0
        list2=[]
        for i in range (len(s)):
        
            list1=[]
            for j in range (i,len(s)):
                
                if s[j] not in list1:
                    list1.append(s[j])
                else:
                    break
            list2.append(len(list1))
        return max(list2)
