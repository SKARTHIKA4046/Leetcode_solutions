class Solution:
    def detectCapitalUse(self, word: str) -> bool:
        
        
        upper_count = 0

        for ch in word:
            if 'A' <= ch <= 'Z':
                upper_count += 1

        if upper_count == len(word):
            return True

        
        if upper_count == 0:
            return True

        # case 3: only first letter uppercase
        if upper_count == 1 and 'A' <= word[0] <= 'Z':
            return True

        return False
